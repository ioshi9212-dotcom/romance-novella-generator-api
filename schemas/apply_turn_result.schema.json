{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/apply_turn_result.schema.json",
  "title": "Novella Apply Turn Result",
  "type": "object",
  "required": [
    "status",
    "applied",
    "rejected",
    "next_builder_hints"
  ],
  "properties": {
    "status": {
      "enum": [
        "applied",
        "partially_applied",
        "rejected",
        "needs_repair"
      ]
    },
    "applied": {
      "type": "object"
    },
    "rejected": {
      "type": "array"
    },
    "next_builder_hints": {
      "type": "object"
    }
  }
}