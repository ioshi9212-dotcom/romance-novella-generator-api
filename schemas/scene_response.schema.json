{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/scene_response.schema.json",
  "title": "Novella Scene Response",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "response_version",
    "scene",
    "proposed_updates",
    "safety_checks",
    "summary",
    "important_facts",
    "witnesses"
  ],
  "properties": {
    "response_version": {
      "const": "novella.scene_response.v1"
    },
    "player_input": {
      "type": "string"
    },
    "scene": {
      "type": "object",
      "required": [
        "header",
        "body",
        "player_options",
        "status_panel",
        "relationships_panel",
        "rendered_text"
      ],
      "properties": {
        "header": {
          "type": "object",
          "required": [
            "story_title",
            "date",
            "time",
            "location",
            "weather",
            "scene_state",
            "player_name",
            "visible_state",
            "outfit",
            "inventory"
          ],
          "properties": {
            "story_title": {
              "type": "string"
            },
            "date": {
              "type": "string"
            },
            "time": {
              "type": "string"
            },
            "location": {
              "type": "string"
            },
            "weather": {
              "type": "string"
            },
            "scene_state": {
              "type": "string"
            },
            "visible_state": {
              "type": "string"
            },
            "outfit": {
              "type": "string"
            },
            "inventory": {
              "type": "string"
            },
            "player_name": {
              "type": "string"
            }
          },
          "not": {
            "anyOf": [
              {
                "required": [
                  "pov"
                ]
              },
              {
                "required": [
                  "focus"
                ]
              },
              {
                "required": [
                  "active_characters"
                ]
              },
              {
                "required": [
                  "active_character_ids"
                ]
              }
            ]
          }
        },
        "body": {
          "type": "string"
        },
        "player_options": {
          "type": "object",
          "required": [
            "thoughts",
            "dialogue",
            "actions"
          ],
          "properties": {
            "thoughts": {
              "type": "array",
              "minItems": 3,
              "maxItems": 3,
              "items": {
                "type": "string"
              }
            },
            "dialogue": {
              "type": "array",
              "minItems": 3,
              "maxItems": 3,
              "items": {
                "type": "string"
              }
            },
            "actions": {
              "type": "array",
              "minItems": 3,
              "maxItems": 3,
              "items": {
                "type": "string"
              }
            }
          }
        },
        "status_panel": {
          "type": "object",
          "required": [
            "hunger",
            "fatigue",
            "injuries",
            "emotional_state",
            "skills",
            "custom"
          ],
          "properties": {
            "hunger": {
              "type": "string"
            },
            "fatigue": {
              "type": "string"
            },
            "injuries": {
              "type": "string"
            },
            "emotional_state": {
              "type": "string"
            },
            "skills": {
              "type": "string"
            },
            "custom": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "items": {
                "type": "object",
                "required": [
                  "id",
                  "label",
                  "value"
                ],
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "label": {
                    "type": "string"
                  },
                  "value": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "relationships_panel": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "label",
              "value"
            ],
            "properties": {
              "pair_id": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            }
          }
        },
        "rendered_text": {
          "type": "string"
        }
      }
    },
    "summary": {
      "type": "string"
    },
    "important_facts": {
      "type": "array"
    },
    "witnesses": {
      "type": "array"
    },
    "proposed_updates": {
      "type": "object",
      "properties": {
        "scene_state_patch": {
          "type": "object"
        },
        "relationship_patches": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "pair_id",
              "change_type",
              "entry",
              "reason",
              "source_in_scene"
            ],
            "properties": {
              "pair_id": {
                "type": "string"
              },
              "change_type": {
                "type": "string"
              },
              "entry": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              },
              "source_in_scene": {
                "type": "string"
              },
              "trust": {
                "type": "number"
              },
              "tension": {
                "type": "number"
              },
              "attachment": {
                "type": "number"
              },
              "respect": {
                "type": "number"
              },
              "fear": {
                "type": "number"
              },
              "scores": {
                "type": "object",
                "additionalProperties": {
                  "type": "number"
                }
              },
              "curiosity": {
                "type": "number"
              },
              "a_view_of_b": {
                "type": "object",
                "additionalProperties": true
              },
              "b_view_of_a": {
                "type": "object",
                "additionalProperties": true
              },
              "trigger_source": {
                "type": "object",
                "additionalProperties": true
              },
              "open_threads": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "knowledge_patches": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "character_id",
              "reason",
              "source_in_scene"
            ],
            "properties": {
              "character_id": {
                "type": "string"
              },
              "add_knows": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "remove_does_not_know": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "add_assumptions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "reason": {
                "type": "string"
              },
              "source_in_scene": {
                "type": "string"
              },
              "add_known_facts": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              },
              "add_observations": {
                "type": "array",
                "items": {
                  "oneOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "object"
                    }
                  ]
                }
              },
              "add_wrong_beliefs": {
                "type": "array",
                "items": {
                  "oneOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "object"
                    }
                  ]
                }
              },
              "add_recent_memories": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "add_open_questions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "source_type": {
                "type": "string"
              },
              "certainty": {
                "type": "string"
              }
            }
          }
        },
        "new_or_updated_characters": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "id",
              "name",
              "role"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "role": {
                "type": "string"
              },
              "introduced": {
                "type": "boolean"
              },
              "known_to_player": {
                "type": "boolean"
              },
              "locked": {
                "type": "boolean"
              }
            }
          }
        }
      }
    },
    "safety_checks": {
      "type": "object",
      "properties": {
        "used_only_loaded_characters": {
          "type": "boolean"
        },
        "respected_knowledge_boundaries": {
          "type": "boolean"
        },
        "no_hidden_future_reveal": {
          "type": "boolean"
        },
        "respected_player_input_order": {
          "type": "boolean"
        },
        "showed_only_scene_relationships": {
          "type": "boolean"
        },
        "header_has_no_focus_or_active_list": {
          "type": "boolean"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "no_major_player_character_choice": {
          "type": "boolean"
        }
      }
    }
  }
}