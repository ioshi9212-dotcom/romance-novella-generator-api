{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/create_session_request.schema.json",
  "title": "Create Session Request",
  "type": "object",
  "additionalProperties": false,
  "required": ["raw_start_text"],
  "properties": {
    "raw_start_text": {
      "type": "string",
      "minLength": 1,
      "description": "Exact complete questionnaire answer in one string. Partial answers are valid; unspecified details are generated."
    },
    "mode": {"enum": ["gpt_actions", "debug_stub"], "default": "gpt_actions"}
  }
}
