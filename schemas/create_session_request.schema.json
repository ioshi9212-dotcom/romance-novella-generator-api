{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/create_session_request.schema.json",
  "title": "Create Session Request",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "title": {"type": ["string", "null"]},
    "genre": {"type": "string", "default": ""},
    "language": {"type": "string", "default": "ru"},
    "tone": {"type": ["string", "null"]},
    "setting_request": {"type": "string", "default": ""},
    "protagonist_request": {"type": "string", "default": ""},
    "romance_request": {"type": ["string", "null"]},
    "rating": {"type": ["string", "null"]},
    "avoid": {"type": "array", "items": {"type": "string"}},
    "extra": {"type": "object"},
    "raw_start_text": {"type": ["string", "null"]},
    "mode": {"enum": ["gpt_actions", "debug_stub"], "default": "gpt_actions"}
  }
}
