{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/scene_contract.schema.json",
  "title": "Novella Scene Contract",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "contract_version",
    "session_id",
    "current_frame",
    "loaded_characters",
    "knowledge_boundaries",
    "director_guidance",
    "output_requirements"
  ],
  "properties": {
    "contract_version": {
      "const": "novella.scene_contract.v1"
    },
    "session_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "current_frame": {
      "type": "object",
      "required": [
        "player_character_id",
        "date",
        "time",
        "location",
        "scene_goal",
        "last_player_input",
        "status"
      ],
      "not": {
        "anyOf": [
          {
            "required": [
              "pov_character_id"
            ]
          },
          {
            "required": [
              "pov_display_name"
            ]
          }
        ]
      }
    },
    "loaded_characters": {
      "type": "array"
    },
    "loaded_relationships": {
      "type": "array"
    },
    "scene_candidates": {
      "type": "object",
      "required": ["characters", "rules"],
      "properties": {
        "characters": {"type": "array", "maxItems": 2},
        "rules": {"type": "object"}
      }
    },
    "knowledge_boundaries": {
      "type": "array"
    },
    "story_compass": {
      "type": "object"
    },
    "time_skip_request": {
      "type": "object"
    },
    "director_guidance": {
      "type": "object"
    },
    "status_slots": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2
    },
    "recent_scene_history": {
      "type": "array"
    },
    "episode_summaries": {
      "type": "array"
    },
    "future_locks": {
      "type": "object"
    },
    "continuity": {
      "type": "object"
    },
    "player_input_rules": {
      "type": "object"
    },
    "output_requirements": {
      "type": "object"
    }
  }
}
